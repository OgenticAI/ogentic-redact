# Rust
/target/
**/*.rs.bk
# Cargo.lock is committed at the workspace root because we ship a binary
# crate (ogentic-redact-cli). Standard Rust convention.

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Allow the Swift package's pre-built-lib directory (tracked with .gitkeep).
!swift/OgenticRedact/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Node
node_modules/
*.node
dist/
.npm/

# Swift / Xcode
.build/
*.xcworkspace
*.xcodeproj
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
# Pre-built Rust static library (generated by scripts/build-swift-ffi.sh).
# Never commit binaries; the CI workflow builds it before `swift test`.
swift/OgenticRedact/lib/*.a

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~
Thumbs.db

# Docs build
docs/_build/
docs/python/_build/

# Test artifacts
tests/vectors/.tmp/

# Claude Code session metadata (per-user, never committed)
.claude/scheduled_tasks.lock

# Linear MCP server debug log — written into the repo root by whichever
# directory the server is launched from. Local tooling output, not ours.
linear_api.log
